{
  "name": "medflow-notification-dispatcher",
  "version": "0.1.0",
  "description": "MedFlow Notification Dispatcher \u2014 Kafka consumer for push and email delivery",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "test": "jest --runInBand --forceExit",
    "test:cov": "jest --coverage",
    "lint": "eslint 'src/**/*.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "kafkajs": "^2.2.4",
    "nodemailer": "^6.9.13",
    "pino": "^9.2.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/nodemailer": "^6.4.15",
    "@types/jest": "^29.5.12",
    "typescript": "^5.4.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=20"
  }
}